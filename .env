FFCODE_1080=ffmpeg -i '{}' -progress '{}' -vf "drawtext=text='cantarellabots':fontcolor=white@0.3:fontsize=26:x=10:y=10" -map 0:v -map 0:a -map 0:s -c:v libx264 -crf 28 -c:s copy -pix_fmt yuv420p -s 1920x1080 -b:v 150k -c:a libopus -b:a 36k -preset ultrafast -threads 0 -metadata title='cantarellabots [t.me/cantarellabots]' -metadata:s:s title='[cantarellabots]' -metadata:s:a title='[cantarellabots]' -metadata author='ABHINAI' -metadata:s:v title='[cantarellabots]' '{}' -y
FFCODE_720=ffmpeg -i '{}' -progress '{}' -vf "drawtext=text='cantarellabots':fontcolor=white@0.3:fontsize=26:x=10:y=10" -map 0:v -map 0:a -map 0:s -c:v libx264 -crf 28 -c:s copy -pix_fmt yuv420p -s 1280x720 -b:v 150k -c:a libopus -b:a 35k -preset ultrafast -threads 0 -metadata title='cantarellabots [t.me/cantarellabots]' -metadata:s:s title='[cantarellabots]' -metadata:s:a title='[cantarellabots]' -metadata author='ABHINAI' -metadata:s:v title='[cantarellabots]' '{}' -y
